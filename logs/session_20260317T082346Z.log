type": "string"}, "title": "Paths", "type": "array"}}, "required": ["paths"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "code_read_file", "description": "", "parameters": {"type": "object", "properties": {"path": {"description": "path", "title": "Path", "type": "string"}}, "required": ["path"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "code_list_directory", "description": "", "parameters": {"type": "object", "properties": {"path": {"default": "", "description": "path", "title": "Path", "type": "string"}}, "required": [], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "code_get_file_info", "description": "", "parameters": {"type": "object", "properties": {"path": {"description": "path", "title": "Path", "type": "string"}}, "required": ["path"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "code_read_multiple_files", "description": "", "parameters": {"type": "object", "properties": {"paths": {"description": "paths", "items": {"type": "string"}, "title": "Paths", "type": "array"}}, "required": ["paths"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "code_search_files", "description": "", "parameters": {"type": "object", "properties": {"path": {"description": "path", "title": "Path", "type": "string"}, "pattern": {"description": "pattern", "title": "Pattern", "type": "string"}}, "required": ["path", "pattern"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "git_status", "description": "", "parameters": {"type": "object", "properties": {}, "required": [], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "git_diff_unstaged", "description": "", "parameters": {"type": "object", "properties": {}, "required": [], "additionalProperties": false}, "
n", "function": {"name": "code_create_directory", "description": "", "parameters": {"type": "object", "properties": {"path": {"description": "path", "title": "Path", "type": "string"}}, "required": ["path"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "code_move_file", "description": "", "parameters": {"type": "object", "properties": {"source": {"description": "source", "title": "Source", "type": "string"}, "destination": {"description": "destination", "title": "Destination", "type": "string"}}, "required": ["source", "destination"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "git_status", "description": "", "parameters": {"type": "object", "properties": {}, "required": [], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "git_diff_unstaged", "description": "", "parameters": {"type": "object", "properties": {}, "required": [], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "git_diff_staged", "description": "", "parameters": {"type": "object", "properties": {}, "required": [], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "git_diff", "description": "", "parameters": {"type": "object", "properties": {"target": {"description": "target", "title": "Target", "type": "string"}}, "required": ["target"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "git_log", "description": "", "parameters": {"type": "object", "properties": {"max_count": {"default": 10, "description": "max_count", "title": "Max Count", "type": "integer"}}, "required": [], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "git_show", "description": "", "parameters": {"type": "object", "properties": {"revision": {"description": "revision", "title": "Revision", "type": "string"}}, "required
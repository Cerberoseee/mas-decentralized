2026-03-11 03:47:49,251 [INFO] autogen_core.events: {"tools": [{"type": "function", "function": {"name": "board_read_file", "description": "Read a ticket or document from the project board (data/project_board/).", "parameters": {"type": "object", "properties": {"path": {"description": "path", "title": "Path", "type": "string"}}, "required": ["path"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "board_write_file", "description": "Create or update a ticket/document on the project board.", "parameters": {"type": "object", "properties": {"path": {"description": "path", "title": "Path", "type": "string"}, "content": {"description": "content", "title": "Content", "type": "string"}}, "required": ["path", "content"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "board_create_directory", "description": "Create a directory on the project board.", "parameters": {"type": "object", "properties": {"path": {"description": "path", "title": "Path", "type": "string"}}, "required": ["path"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "board_list_directory", "description": "List entries on the project board.", "parameters": {"type": "object", "properties": {"path": {"default": "", "description": "path", "title": "Path", "type": "string"}}, "required": [], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "board_get_file_info", "description": "Get metadata for a board path.", "parameters": {"type": "object", "properties": {"path": {"description": "path", "title": "Path", "type": "string"}}, "required": ["path"], "additionalProperties": false}, "strict": false}}, {"type": "function", "function": {"name": "board_read_multiple_files", "description": "Read multiple board files at once.", "parameters": {"type": "object", "properties": {"paths": {"description": "paths", "items": {"type": "string"}, "title"